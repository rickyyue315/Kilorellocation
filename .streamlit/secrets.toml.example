# Zeabur: 請在 Zeabur Dashboard → Secrets 設定這些環境變數
# 不要直接修改 secrets.toml（已加入 .gitignore）
# 複製此檔案為 secrets.toml 並填入真實值（僅供本地開發用）

OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AI_ENABLED = true
AI_MODEL = "deepseek/deepseek-v4-flash"
AI_FALLBACK_MODEL = "inclusionai/ling-2.6-flash"
AI_REQUEST_TIMEOUT = 30
OPENROUTER_SITE_URL = "https://kilorellocation-glm46.streamlit.app/"
OPENROUTER_APP_TITLE = "KiLo Reallocation"
